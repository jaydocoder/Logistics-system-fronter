# 前端依赖包（绝对不能传）
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 环境变量（密钥不能传）
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 编辑器/IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store（Windows 可删）

# 构建打包产物（打包后生成的，不用传）
dist/
build/
output/
*.local

# 日志
logs/
*.log

# 测试/覆盖率
coverage/
.nyc_output/

# 临时文件
*.tmp
*.temp
.cache/
.temp/

# Windows 系统垃圾
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Claude 相关目录
.claude/

# Omc 相关目录（包含项目记忆与会话）
.omc/